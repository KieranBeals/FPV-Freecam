{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "license": "${mod_license}",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.kieran.fpvfreecam.fabric.FpvFreecamFabricClient"
    ],
    "modmenu": [
      "com.kieran.fpvfreecam.fabric.FpvFreecamModMenu"
    ]
  },
  "mixins": [
    "fpvfreecam.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": ">=${minecraft_version}",
    "fabric-api": ">=${fabric_api_version}",
    "modmenu": ">=${modmenu_version}"
  }
}
